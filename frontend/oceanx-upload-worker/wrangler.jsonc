/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "oceanx-upload-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-07",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "oceanx-media"
		}
	],
	"vars": {
		"PUBLIC_URL": "https://oceanx-media.com",
		"ALLOWED_ORIGIN": "https://cms.oceanx.sa",
		"FIREBASE_PROJECT_ID": "oceanx-backend-dev"
	}
}