PORT=4000
FRONTEND_URL=http://localhost:5174

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oceanx_cms
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# File uploads (local storage by default)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Optional: AWS S3 (leave empty to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
